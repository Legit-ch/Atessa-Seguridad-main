# Copie este archivo a .env y configure sus credenciales reales.
# No agregue .env al repositorio. .gitignore ya lo excluye.

DB_HOST=127.0.0.1
DB_NAME=atessa_security
DB_USER=tu_usuario
DB_PASS=tu_contraseña_segura
DB_CHARSET=utf8mb4

# Usuario administrador
ADMIN_USER=admin
# En lugar de guardar la contraseña en texto claro, guarde el hash generado por PHP:
# php -r "echo password_hash('TU_PASSWORD_ADMIN', PASSWORD_DEFAULT) . PHP_EOL;"
ADMIN_PASS_HASH=$2y$REEMPLACE_POR_EL_HASH_GENERADO
